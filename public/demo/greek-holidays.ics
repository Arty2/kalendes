BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//calendar-timeline//Greek Public Holidays demo//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Greek Public Holidays
X-WR-TIMEZONE:Europe/Athens
BEGIN:VEVENT
UID:gr-newyear@calendar-timeline
SUMMARY:New Year's Day (Πρωτοχρονιά)
DESCRIPTION:Public holiday in Greece marking the start of the new year.
DTSTART;VALUE=DATE:20240101
DTEND;VALUE=DATE:20240102
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-epiphany@calendar-timeline
SUMMARY:Epiphany (Θεοφάνεια)
DESCRIPTION:Orthodox Christian feast commemorating the baptism of Jesus. Blessing of the waters takes place across Greece.
DTSTART;VALUE=DATE:20240106
DTEND;VALUE=DATE:20240107
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-independence@calendar-timeline
SUMMARY:Independence Day (25η Μαρτίου)
DESCRIPTION:Commemorates the start of the Greek War of Independence in 1821. Coincides with the Annunciation feast.
DTSTART;VALUE=DATE:20240325
DTEND;VALUE=DATE:20240326
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-labour@calendar-timeline
SUMMARY:Labour Day (Πρωτομαγιά)
DESCRIPTION:May Day. International workers' day; traditional flower garlands are hung on doors.
DTSTART;VALUE=DATE:20240501
DTEND;VALUE=DATE:20240502
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-assumption@calendar-timeline
SUMMARY:Assumption of Mary (Κοίμηση της Θεοτόκου)
DESCRIPTION:Major Orthodox feast marking the dormition of the Virgin Mary. One of the largest religious celebrations in Greece.
DTSTART;VALUE=DATE:20240815
DTEND;VALUE=DATE:20240816
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-ohi@calendar-timeline
SUMMARY:Ohi Day (Επέτειος του Όχι)
DESCRIPTION:Commemorates Greece's refusal of Mussolini's 1940 ultimatum. Marked with parades nationwide.
DTSTART;VALUE=DATE:20241028
DTEND;VALUE=DATE:20241029
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-christmas@calendar-timeline
SUMMARY:Christmas Day (Χριστούγεννα)
DESCRIPTION:Orthodox celebration of the birth of Jesus Christ.
DTSTART;VALUE=DATE:20241225
DTEND;VALUE=DATE:20241226
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
BEGIN:VEVENT
UID:gr-boxing@calendar-timeline
SUMMARY:Synaxis of the Theotokos (Σύναξη της Υπεραγίας Θεοτόκου)
DESCRIPTION:Second day of Christmas in the Orthodox tradition; honors the Mother of God.
DTSTART;VALUE=DATE:20241226
DTEND;VALUE=DATE:20241227
RRULE:FREQ=YEARLY;COUNT=10
END:VEVENT
